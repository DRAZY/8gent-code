{
  "allowedPatterns": [
    "npm *",
    "bun *",
    "yarn *",
    "pnpm *",
    "git status",
    "git log*",
    "git diff*",
    "git branch*",
    "git checkout*",
    "git add*",
    "git commit*",
    "git pull",
    "git fetch",
    "git stash*",
    "git show*",
    "ls*",
    "cat *",
    "head *",
    "tail *",
    "grep *",
    "find *",
    "tree *",
    "wc *",
    "echo *",
    "pwd",
    "date",
    "which *",
    "tsc *",
    "esbuild *",
    "vite *",
    "next *",
    "jest *",
    "vitest *",
    "eslint *",
    "prettier *",
    "biome *"
  ],
  "deniedPatterns": [
    "rm -rf /",
    "rm -rf ~",
    "rm -rf /*",
    "sudo rm -rf*",
    ":(){ :|:& };:",
    "dd if=/dev/*",
    "mkfs*",
    "> /dev/sda*",
    "chmod -R 777 /",
    "curl * | sh",
    "wget * | sh",
    "curl * | bash",
    "wget * | bash"
  ],
  "autoApprove": false,
  "logPath": null
}
