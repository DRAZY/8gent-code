.claude/worktrees/

# Audio files (too large for git, regenerate with sync-audio.ts)
docs/audio/*.aiff
docs/branch-audio/*.aiff

# UI sample outputs (artifacts belong in 8gent-world, not the harness)
benchmarks/ui-samples/
benchmarks/artifacts/

# Ecosystem media (canonical: 8gent-world public/media)
/media/

# Local reference clone (nested .git; do not commit)
claude-code/

# Content drafts (belong in ~/Myresumeportfolio/content/)
docs/content/

# Lil Eight build artifacts (rebuild with: bun run pet:build)
apps/lil-eight/build/

