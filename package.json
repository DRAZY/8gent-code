{
  "name": "8gent-code",
  "version": "0.1.0",
  "private": false,
  "description": "Terminal-first agentic coding with 40%+ token savings. Never hit usage caps again.",
  "type": "module",
  "bin": {
    "8gent": "./bin/8gent.ts"
  },
  "scripts": {
    "start": "bun run bin/8gent.ts",
    "dev": "bun run apps/tui/src/index.ts",
    "build": "bun build apps/tui/src/index.ts --outdir dist",
    "test": "bun test",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "benchmark": "bun run scripts/benchmark.ts",
    "demo": "bun run scripts/demo-savings.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0",
    "@biomejs/biome": "^1.5.0"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "tree-sitter": "^0.21.0",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-javascript": "^0.21.0",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-rust": "^0.21.0",
    "tree-sitter-typescript": "^0.21.0"
  },
  "author": "James Spalding",
  "license": "MIT"
}
