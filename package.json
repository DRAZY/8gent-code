{
  "name": "8gent-code",
  "version": "0.4.3",
  "private": false,
  "description": "The Infinite Gentleman - Autonomous agentic coding. Never hit usage caps again.",
  "type": "module",
  "bin": {
    "8": "./dist/cli.js",
    "8gent": "./dist/cli.js",
    "8gent-code": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun run packages/eight/index.ts",
    "agent": "bun run packages/eight/index.ts",
    "tui": "bun run apps/tui/src/index.tsx",
    "install-wizard": "bun run apps/installer/src/index.tsx",
    "cli": "bun run bin/8gent.ts",
    "dev": "next dev",
    "build": "bun build packages/eight/index.ts --outfile dist/cli.js --target node && chmod +x dist/cli.js",
    "build:tui": "bun build apps/tui/src/index.tsx --outdir dist/tui --target node",
    "prepublishOnly": "npm run build",
    "postinstall": "node -e \"console.log('\\n✨ 8gent installed! Run: 8gent\\n\\nPrerequisite: Ollama must be running.\\nInstall Ollama: https://ollama.ai\\nStart it: ollama serve\\nPull a model: ollama pull qwen3.5\\n')\"",
    "test": "bun test",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "benchmark": "bun run scripts/benchmark.ts",
    "benchmark:suite": "bun run benchmarks/runner.ts",
    "benchmark:category": "bun run benchmarks/runner.ts --category",
    "benchmark:single": "bun run benchmarks/runner.ts --bench",
    "demo": "bun run scripts/demo-savings.ts",
    "harness": "bun run packages/harness-cli/index.ts",
    "harness:run": "bun run packages/harness-cli/index.ts run",
    "harness:sessions": "bun run packages/harness-cli/index.ts sessions",
    "harness:inspect": "bun run packages/harness-cli/index.ts inspect",
    "harness:doctor": "bun run packages/harness-cli/index.ts doctor"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^1.5.0",
    "@types/bun": "latest",
    "@types/jsdom": "^28.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@mozilla/readability": "^0.6.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.14",
    "ai": "^6.0.116",
    "cheerio": "^1.2.0",
    "glob": "^13.0.6",
    "ink": "^6.8.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "jsdom": "^28.1.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "sharp": "^0.34.5",
    "tree-sitter": "^0.21.0",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-javascript": "^0.21.0",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-rust": "^0.21.0",
    "tree-sitter-typescript": "^0.21.0",
    "zod": "^4.3.6"
  },
  "author": "James Spalding",
  "license": "MIT"
}
