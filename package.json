{
  "name": "@podjamz/8gent-code",
  "version": "2.0.0",
  "private": false,
  "description": "The Infinite Gentleman - Autonomous agentic coding. Never hit usage caps again.",
  "type": "module",
  "bin": {
    "8": "./dist/cli.js",
    "8gent": "./dist/cli.js",
    "8gent-code": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun run packages/eight/index.ts",
    "agent": "bun run packages/eight/index.ts",
    "tui": "bun run apps/tui/src/index.tsx",
    "pet": "bash apps/lil-eight/build.sh && open 'apps/lil-eight/build/Lil Eight.app'",
    "pet:build": "bash apps/lil-eight/build.sh",
    "pet:open": "open 'apps/lil-eight/build/Lil Eight.app'",
    "pet:kill": "pkill -f LilEight",
    "pet:log": "tail -f ~/.8gent/lil-eight.log",
    "install-wizard": "bun run apps/installer/src/index.tsx",
    "cli": "bun run bin/8gent.ts",
    "dev": "next dev",
    "build": "bun build bin/8gent.ts --outfile dist/cli.js --target bun && sed -i '' '1i\\\n#!/usr/bin/env bun' dist/cli.js && chmod +x dist/cli.js",
    "build:tui": "bun build apps/tui/src/index.tsx --outdir dist/tui --target node",
    "prepublishOnly": "npm run build",
    "postinstall": "node -e \"console.log('\\n✨ 8gent installed! Just type: 8gent\\n\\nFirst run will guide you through Ollama setup if needed.\\n')\" && npx bmad-method init --no-interactive 2>/dev/null || true",
    "test": "bun test",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "benchmark": "bun run scripts/benchmark.ts",
    "benchmark:suite": "bun run benchmarks/runner.ts",
    "benchmark:category": "bun run benchmarks/runner.ts --category",
    "benchmark:single": "bun run benchmarks/runner.ts --bench",
    "demo": "bun run scripts/demo-savings.ts",
    "harness": "bun run packages/harness-cli/index.ts",
    "harness:run": "bun run packages/harness-cli/index.ts run",
    "harness:sessions": "bun run packages/harness-cli/index.ts sessions",
    "harness:inspect": "bun run packages/harness-cli/index.ts inspect",
    "harness:doctor": "bun run packages/harness-cli/index.ts doctor",
    "demos:studio": "cd apps/demos && bun run studio",
    "demos:render": "cd apps/demos && bun run render:all",
    "demos:media": "cd apps/demos && bun run media",
    "debug": "bun run bin/debug.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^1.5.0",
    "@changesets/cli": "^2.30.0",
    "@napi-rs/canvas": "^0.1.97",
    "@types/bun": "latest",
    "@types/jsdom": "^28.0.0",
    "bmad-method": "^6.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@mozilla/readability": "^0.6.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.14",
    "ai": "^6.0.116",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "glob": "^13.0.6",
    "ink": "^6.8.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "jsdom": "^28.1.0",
    "miniflare": "^4.20260317.1",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "sharp": "^0.34.5",
    "stripe": "^17.7.0",
    "tree-sitter": "^0.21.0",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-javascript": "^0.21.0",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-rust": "^0.21.0",
    "tree-sitter-typescript": "^0.21.0",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "James Spalding",
  "license": "MIT"
}
