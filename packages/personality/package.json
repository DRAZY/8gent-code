{
  "name": "@8gent/personality",
  "version": "0.1.0",
  "description": "8gent Code personality system - The Infinite Gentleman",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./status-verbs": {
      "import": "./dist/status-verbs.js",
      "types": "./dist/status-verbs.d.ts"
    },
    "./voice": {
      "import": "./dist/voice.js",
      "types": "./dist/voice.d.ts"
    },
    "./brand": {
      "import": "./dist/brand.js",
      "types": "./dist/brand.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "8gent",
    "personality",
    "tui",
    "cli",
    "agent"
  ],
  "author": "James Spalding",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
