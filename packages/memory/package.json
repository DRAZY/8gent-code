    },
    "./store": {
      "import": "./store.ts",
      "types": "./store.ts"
    },
    "./embeddings": {
      "import": "./embeddings.ts",
      "types": "./embeddings.ts"
    },
    "./migrate": {
      "import": "./migrate.ts",
      "types": "./migrate.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
