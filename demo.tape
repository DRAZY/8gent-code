# VHS Tape - 8gent Code Demo v0.2.0
# Install: brew install vhs
# Run: vhs demo.tape

Output demo.gif

Set Shell "bash"
Set FontSize 14
Set Width 900
Set Height 600
Set Theme "Catppuccin Mocha"
Set TypingSpeed 40ms

Type "# 8gent Code - The Infinite Gentleman"
Enter
Sleep 1s

Type "# Autonomous agentic coding powered by local LLMs"
Enter
Sleep 1s

Type "8gent"
Enter
Sleep 2s

# Show the interactive prompt
Type "/status"
Enter
Sleep 2s

Type "/models"
Enter
Sleep 2s

# Show slash commands
Type "/help"
Enter
Sleep 3s

# Demo a task
Type "Create a simple React counter component with TypeScript"
Enter
Sleep 8s

# Show AST-first code navigation
Type "/exit"
Enter
Sleep 1s

Type "# AST-First Code Navigation - 97% Token Savings"
Enter
Sleep 1s

Type "# Instead of reading entire files..."
Enter
Sleep 500ms

Type "8gent outline packages/planner/index.ts"
Enter
Sleep 3s

Type "# ...get just the symbols you need"
Enter
Sleep 500ms

Type "8gent symbol packages/planner/index.ts::Planner"
Enter
Sleep 3s

Type "# Run benchmark on your codebase"
Enter
Sleep 500ms

Type "bun run benchmark"
Enter
Sleep 5s

Type ""
Enter
Sleep 500ms

Type "# Features: MCP, LSP, Web Search, Multi-Agent, Hooks, Permissions"
Enter
Sleep 1s

Type "# github.com/PodJamz/8gent-code"
Enter
Sleep 2s
